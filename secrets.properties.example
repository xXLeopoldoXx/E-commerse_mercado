# Plantilla de secretos locales.
# Copia este archivo como "secrets.properties" (sin .example) y rellena tus datos.
# El archivo "secrets.properties" esta en .gitignore: NO se sube al repositorio.

# Correo Gmail que envia los mensajes (remitente del sistema)
MAIL_USERNAME=tucorreo@gmail.com
# Contrasena de aplicacion de Gmail (16 caracteres, sin espacios)
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
